<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Teleprompter theme — colour palette (dark, Fluent-flavoured)
         One warm-amber accent for primary actions + the active
         prompter sentence; a cool teal reserved for the second audio
         path (incoming-audio transcription) so the two never blur.
         ============================================================ -->

    <!-- Surfaces -->
    <SolidColorBrush x:Key="WindowBrush"           Color="#1E1E1F" />
    <SolidColorBrush x:Key="TitleBarBrush"         Color="#171718" />
    <SolidColorBrush x:Key="CardBrush"             Color="#252527" />
    <SolidColorBrush x:Key="CardHeaderBorderBrush" Color="#2F2F31" />
    <SolidColorBrush x:Key="InputBrush"            Color="#161617" />
    <SolidColorBrush x:Key="BorderBrush"           Color="#323234" />
    <SolidColorBrush x:Key="BorderSubtleBrush"     Color="#2E2E30" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#F2F2F2" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A8A8A8" />
    <SolidColorBrush x:Key="TextTertiaryBrush"  Color="#6A6A6C" />

    <!-- Accent — amber ("on air") -->
    <SolidColorBrush x:Key="AccentBrush"        Color="#E8A33D" />
    <SolidColorBrush x:Key="AccentHoverBrush"   Color="#F3B655" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#D8922C" />
    <SolidColorBrush x:Key="OnAccentBrush"      Color="#1A1200" />
    <SolidColorBrush x:Key="AccentSoftBrush"    Color="#26E8A33D" />

    <!-- Teal — incoming-audio transcription (the second, distinct path) -->
    <SolidColorBrush x:Key="TealBrush"     Color="#40C4C4" />
    <SolidColorBrush x:Key="TealTextBrush" Color="#7ED6D6" />
    <SolidColorBrush x:Key="TealSoftBrush" Color="#2640C4C4" />

    <!-- Danger -->
    <SolidColorBrush x:Key="DangerBrush"     Color="#E0524E" />
    <SolidColorBrush x:Key="DangerTextBrush" Color="#F0938F" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#26E0524E" />

    <!-- Control chrome -->
    <SolidColorBrush x:Key="TrackBrush"          Color="#3A3A3D" />
    <SolidColorBrush x:Key="SecondaryBrush"      Color="#333336" />
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#3D3D40" />
    <SolidColorBrush x:Key="GhostBrush"          Color="#2C2C2F" />
    <SolidColorBrush x:Key="ThumbBrush"          Color="#F4F4F4" />

    <!-- Status-bar levels (bg / border / dot handled in code-behind) -->
    <SolidColorBrush x:Key="Status.Info.Bg"       Color="#2A2A2C" />
    <SolidColorBrush x:Key="Status.Info.Border"   Color="#38383A" />
    <SolidColorBrush x:Key="Status.Progress.Bg"   Color="#26E8A33D" />
    <SolidColorBrush x:Key="Status.Progress.Border" Color="#52E8A33D" />
    <SolidColorBrush x:Key="Status.Live.Bg"       Color="#29E8A33D" />
    <SolidColorBrush x:Key="Status.Live.Border"   Color="#57E8A33D" />
    <SolidColorBrush x:Key="Status.Error.Bg"      Color="#26E0524E" />
    <SolidColorBrush x:Key="Status.Error.Border"  Color="#5CE0524E" />

</ResourceDictionary>
